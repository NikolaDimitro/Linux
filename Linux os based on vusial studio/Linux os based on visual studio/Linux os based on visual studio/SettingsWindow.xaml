<Window x:Class="LinuxMintOS.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Settings" 
        Height="400" 
        Width="600"
        Background="#f5f5f5"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="System Settings" FontSize="24" Foreground="#1a3a0b" FontWeight="Bold" Margin="0,0,0,20"/>

            <GroupBox Header="Display" Margin="0,0,0,15" Padding="15">
                <StackPanel>
                    <CheckBox Content="Dark Theme" IsChecked="False" Margin="0,5"/>
                    <CheckBox Content="Enable Animations" IsChecked="True" Margin="0,5"/>
                    <TextBlock Text="Resolution: 1920x1080" Margin="0,10,0,0"/>
                    <TextBlock Text="Refresh Rate: 60 Hz" Margin="0,5,0,0"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Sound" Margin="0,0,0,15" Padding="15">
                <StackPanel>
                    <TextBlock Text="Volume: 70%" Margin="0,0,0,10"/>
                    <Slider Value="70" Maximum="100" Minimum="0" Margin="0,0,0,10"/>
                    <CheckBox Content="Enable Sound Effects" IsChecked="True"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="About" Padding="15">
                <StackPanel>
                    <TextBlock Text="Linux Mint OS Simulator" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="Version: 1.0" Margin="0,0,0,5"/>
                    <TextBlock Text="Based on .NET Framework WPF" Margin="0,0,0,5"/>
                </StackPanel>
            </GroupBox>

            <Button Content="Apply Changes" Background="#4CAF50" Foreground="White" Padding="10,10" Margin="0,20,0,0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>