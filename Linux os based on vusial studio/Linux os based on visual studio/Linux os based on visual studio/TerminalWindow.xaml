<Window x:Class="LinuxMintOS.TerminalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Terminal" 
        Height="400" 
        Width="700"
        Background="#000000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- Terminal Output -->
        <TextBox Grid.Row="0" x:Name="TerminalOutput" 
                 Background="#000000" Foreground="#00FF00" 
                 FontFamily="Courier New" FontSize="12"
                 TextWrapping="Wrap" AcceptsReturn="True"
                 IsReadOnly="True" Margin="5"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>

        <!-- Terminal Input -->
        <Grid Grid.Row="1" Background="#1a1a1a" Margin="5,0,5,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="user@mint:~$ " Foreground="#00FF00" VerticalAlignment="Center" Margin="5,0"/>
                <TextBox x:Name="CommandInput" 
                         Background="#1a1a1a" Foreground="#00FF00"
                         FontFamily="Courier New" FontSize="12"
                         VerticalAlignment="Center"
                         KeyDown="CommandInput_KeyDown"
                         BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>