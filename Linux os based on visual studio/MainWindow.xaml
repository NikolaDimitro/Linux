<Window x:Class="LinuxMintOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Linux Mint OS" 
        WindowState="Maximized"
        Background="#2d5016"
        WindowStyle="None"
        ResizeMode="NoResize">
    <Grid>
        <!-- Define Row Definitions FIRST -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Wallpaper Background -->
        <Image Grid.Row="0" Grid.RowSpan="2" Source="Assets/wallpaper.jpg" Stretch="UniformToFill" />

        <!-- Overlay for better readability -->
        <Rectangle Grid.Row="0" Grid.RowSpan="2" Fill="#000000" Opacity="0.3"/>

        <!-- Desktop Content -->
        <Grid Grid.Row="0">
            <StackPanel Margin="20" VerticalAlignment="Top">
                <TextBlock Text="Desktop" FontSize="24" Foreground="#FFFFFF" FontWeight="Bold" Margin="0,0,0,20"/>
                <WrapPanel x:Name="DesktopAppsPanel">
                    <Button Click="FileManager_Click" Style="{StaticResource ButtonStyle}" Margin="5" Width="150" Height="48" FontSize="12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="Assets/files.png" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Files" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="Browser_Click" Style="{StaticResource ButtonStyle}" Margin="5" Width="150" Height="48" FontSize="12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="Assets/browser.png" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Browser" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="Terminal_Click" Style="{StaticResource ButtonStyle}" Margin="5" Width="150" Height="48" FontSize="12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="Assets/terminal.png" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Terminal" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="Settings_Click" Style="{StaticResource ButtonStyle}" Margin="5" Width="150" Height="48" FontSize="12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="Assets/settings.png" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="TextEditor_Click" Style="{StaticResource ButtonStyle}" Margin="5" Width="150" Height="48" FontSize="12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="Assets/text-editor.png" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Text Editor" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </StackPanel>
        </Grid>

        <!-- Taskbar -->
        <Border x:Name="TaskbarBorder" Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#66FFFFFF" Background="#CC101820">
            <Grid x:Name="TaskbarGrid" Background="#CC1B2633">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                    <!-- Menu Button -->
                    <Button Content="🍃 Menu" Click="Menu_Click" Background="#AA2E7D32" Foreground="White" 
                            Padding="15,5" Margin="5,0" FontWeight="Bold" Cursor="Hand"
                            Style="{StaticResource ButtonStyle}"/>

                    <!-- Taskbar Items -->
                    <ItemsControl x:Name="TaskbarItems">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Margin="10,0"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" Background="#333333" Foreground="White" 
                                        Padding="10,5" Margin="5,0" Cursor="Hand"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Clock and System Tray -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0">
                    <TextBlock x:Name="ClockDisplay" Text="00:00" Foreground="#FFFFFFFF" FontSize="14" FontWeight="Bold" Margin="0,0,15,0"/>
                    <TextBlock Text="🔊" FontSize="16" Margin="5,0"/>
                    <TextBlock Text="🔋" FontSize="16" Margin="5,0"/>
                    <TextBlock Text="📶" FontSize="16" Margin="5,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>