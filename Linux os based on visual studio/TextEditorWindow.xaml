<Window x:Class="LinuxMintOS.TextEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Text Editor" 
        Height="500" 
        Width="800"
        Background="#f5f5f5"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#e8e8e8" Margin="10,6,10,6">
            <Button Content="📄 New" Click="New_Click" Background="#4CAF50" Foreground="White" 
                    Padding="10,5" Margin="5" Cursor="Hand"/>
            <Button Content="📂 Open" Click="Open_Click" Background="#2196F3" Foreground="White" 
                    Padding="10,5" Margin="5" Cursor="Hand"/>
            <Button Content="💾 Save" Click="Save_Click" Background="#FF9800" Foreground="White" 
                    Padding="10,5" Margin="5" Cursor="Hand"/>
        </StackPanel>

        <!-- Text Area -->
        <TextBox Grid.Row="1" x:Name="EditorText" 
                 Background="White" Foreground="Black"
                 FontFamily="Courier New" FontSize="12"
                 TextWrapping="Wrap" AcceptsReturn="True"
                 Margin="5"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
    </Grid>
</Window>