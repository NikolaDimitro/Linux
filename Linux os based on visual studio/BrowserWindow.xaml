<Window x:Class="LinuxMintOS.BrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Web Browser" 
        Height="600" 
        Width="1000"
        Background="#f0f0f0"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#e8e8e8" Margin="10,6,10,6">
            <Button Content="◀ Back" Click="Back_Click" Background="#4CAF50" Foreground="White" 
                    Padding="10,5" Margin="5" Cursor="Hand" Width="60"/>
            <Button Content="▶ Forward" Click="Forward_Click" Background="#4CAF50" Foreground="White" 
                    Padding="10,5" Margin="5" Cursor="Hand" Width="70"/>
            <Button Content="🔄 Refresh" Click="Refresh_Click" Background="#2196F3" Foreground="White" 
                    Padding="10,5" Margin="5" Cursor="Hand" Width="70"/>
            <Button Content="🏠 Home" Click="Home_Click" Background="#FF9800" Foreground="White" 
                    Padding="10,5" Margin="5" Cursor="Hand" Width="60"/>
        </StackPanel>

        <!-- Address Bar -->
        <Grid Grid.Row="1" Background="#e8e8e8" Margin="10,5,10,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔒" FontSize="16" VerticalAlignment="Center" Margin="5,0"/>
                <TextBox x:Name="AddressBar" 
                         Background="White" Foreground="Black"
                         VerticalAlignment="Center"
                         KeyDown="AddressBar_KeyDown"
                         Margin="5,0"/>
                <Button Content="Go" Click="Navigate_Click" Background="#4CAF50" Foreground="White" 
                        Padding="10,5" Margin="5" Cursor="Hand" Width="50"/>
            </StackPanel>
        </Grid>

        <!-- WebView2 Control -->
        <Grid x:Name="WebViewContainer" Grid.Row="2" Margin="5" Background="White"/>
    </Grid>
</Window>